TELEGRAM_BOT_TOKEN=your-telegram-bot-token
ANTHROPIC_API_KEY=your-anthropic-api-key
OWNER_TELEGRAM_ID=your-telegram-user-id
POSTGRES_PASSWORD=change-me-in-production

# LLM provider: anthropic | grok | openai
LLM_PROVIDER=anthropic

# Redis
REDIS_URL=redis://redis:6379/0

# Postgres
DATABASE_URL=postgresql://userid:password@postgres:5432/personal_bot

# Agent-core internal URL (no host port exposed)
AGENT_CORE_URL=http://agent-core:8000